{
  "metadata": [
    {
      "src": [
        {
          "src": ".",
          "files": [
            "src/QwenCode.Core/QwenCode.Core.csproj",
            "src/QwenCode.App/QwenCode.App.csproj"
          ]
        }
      ],
      "dest": "api"
    }
  ],
  "build": {
    "content": [
      {
        "files": [
          "docs/**/*.md",
          "toc.yml",
          "api/**.yml"
        ]
      }
    ],
    "resource": [
      {
        "files": [
          "docs/images/**"
        ]
      }
    ],
    "output": "_site",
    "template": [
      "default",
      "modern"
    ]
  }
}
